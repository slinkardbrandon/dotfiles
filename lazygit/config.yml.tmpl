# DO NOT EDIT — generated from config.yml.tmpl by theme engine
gui:
  # Show file icons (requires nerd font — you have FiraCode Nerd Font)
  nerdFontsVersion: "3"
  # Border style
  border: rounded
  # Theme
  theme:
    activeBorderColor:
      - "{{colors.secondary}}"
      - bold
    inactiveBorderColor:
      - "{{colors.comment}}"
    searchingActiveBorderColor:
      - "{{colors.cyan}}"
      - bold
    optionsTextColor:
      - "{{colors.accent}}"
    selectedLineBgColor:
      - "{{colors.selectedLineBg}}"
    cherryPickedCommitFgColor:
      - "{{colors.cyan}}"
    cherryPickedCommitBgColor:
      - "{{colors.selectedLineBg}}"
    unstagedChangesColor:
      - "{{colors.red}}"
    defaultFgColor:
      - "{{colors.fg}}"
git:
  # Auto-fetch every 60 seconds
  autoFetch: true
  autoFetchInterval: 60
  # Show branch graph
  log:
    showGraph: always
  pagers:
    - colorArg: always
      pager: >-
        delta --dark --paging=never --line-numbers --syntax-theme="{{bat.syntaxTheme}}" --word-diff-regex="\S+" --minus-style="syntax {{colors.diffMinusStyle}}" --minus-emph-style="syntax {{colors.diffMinusEmph}}" --plus-style="syntax {{colors.diffPlusStyle}}" --plus-emph-style="syntax {{colors.diffPlusEmph}}" --whitespace-error-style="reverse {{colors.diffWhitespaceError}}" --line-numbers-minus-style="{{colors.diffLineNumMinus}}" --line-numbers-plus-style="{{colors.diffLineNumPlus}}" --line-numbers-zero-style="{{colors.comment}}"
os:
  editPreset: "nvim"
  open: 'tmux new-window nvim -- {{filename}}'
# Confirm before force push or discard
disableStartupPopups: true
