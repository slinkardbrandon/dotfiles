[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[commit]
	gpgsign = true
	template = ~/.gitmessage

[push]
	autoSetupRemote = true
	default = current

[pull]
	rebase = true

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	autocrlf = input

[init]
	defaultBranch = main

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	last = log -1 HEAD
	undo = reset HEAD~1 --mixed
	amend = commit --amend --no-edit

[diff]
	tool = vscode

[merge]
	tool = vscode
	conflictstyle = diff3

[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE

[mergetool "vscode"]
	cmd = code --wait $MERGED

[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential
[url "https://github.com/"]
	insteadOf = git@github.com:

# Machine-specific overrides (identity, signing, per-machine credential routing) — gitignored.
# Loaded after the defaults above so machine-local settings win.
[include]
	path = ~/.gitconfig.local

# Personal identity for the dotfiles repo itself — must load LAST so it overrides
# any work identity that ~/.gitconfig.local applies to ~/dotfiles on a work machine.
[includeIf "gitdir:~/dotfiles/"]
	path = ~/.gitconfig.personal
